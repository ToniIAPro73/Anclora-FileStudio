{
  "permissions": {
    "allow": [
      "Bash(pnpm install *)",
      "Bash(pnpm lint)",
      "Bash(pnpm typecheck)",
      "Bash(pnpm test *)",
      "Bash(pnpm build *)",
      "Bash(pnpm check)",
      "Bash(curl -s http://localhost:*)",
      "Bash(curl -s -X * http://localhost:*)",
      "Bash(python3 -m json.tool)",
      "Bash(jq *)",
      "Bash(awk *)",
      "Bash(grep *)",
      "Bash(memanto *)"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "memanto memory sync --project-dir .",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

